---
const currentYear = new Date().getFullYear();
const tools = [
    { href: '/tools/salary-calculator', label: '薪資計算' },
    { href: '/tools/mortgage-calculator', label: '房貸試算' },
    { href: '/tools/fire-calculator', label: 'FIRE 退休' },
    { href: '/tools/overtime-calculator', label: '加班費' },
    { href: '/tools/electricity-calculator', label: '電費試算' },
];
---
<footer class="border-t border-paper-300 pt-10 pb-8 mt-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
        <!-- Brand -->
        <div>
            <a href="/" class="text-base font-semibold text-ink-700 hover:text-ink-500 transition-colors">TaiCalc</a>
            <p class="text-xs text-ink-400 mt-2 leading-relaxed max-w-xs">
                專為台灣人設計的免費財務計算工具。<br>
                所有計算均在本地執行，資料不傳送至伺服器。
            </p>
        </div>
        <!-- Tool Links -->
        <div>
            <p class="text-xs font-medium text-ink-400 uppercase tracking-widest mb-3">常用工具</p>
            <div class="grid grid-cols-2 gap-x-4 gap-y-2">
                {tools.map(t => (
                    <a href={t.href} class="text-xs text-ink-400 hover:text-ink-700 transition-colors">{t.label}</a>
                ))}
            </div>
        </div>
    </div>
    <div class="flex items-center justify-between border-t border-paper-300 pt-6">
        <p class="text-xs text-ink-400">© {currentYear} TaiCalc</p>
        <a href="mailto:service@taicalc.com" class="text-xs text-ink-400 hover:text-ink-600 transition-colors">回報問題</a>
    </div>
</footer>
