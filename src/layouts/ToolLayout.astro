---
import Layout from './Layout.astro';
import { platformGovernance, type SourceLink } from '../data/regulatoryMetadata';
import { getRelatedTools, getToolByHref, normalizeToolPath } from '../data/toolCatalog';

interface Props {
  title: string;
  description: string;
  category?: string;
  faqs?: { q: string; a: string }[];
  keywords?: string;
  kicker?: string;
  dataVersion?: string;
  dataYear?: string;
  lastUpdated?: string;
  sources?: SourceLink[];
}

const {
  title,
  description,
  category = "工具",
  faqs = [],
  keywords,
  kicker = "先算，再看細節",
  dataVersion = platformGovernance.version,
  dataYear = platformGovernance.dataYear,
  lastUpdated = platformGovernance.updatedAt,
  sources = platformGovernance.sources
} = Astro.props;

const faqSchema = faqs.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a,
      "dateCreated": new Date().toISOString().split('T')[0]
    }
  }))
}) : null;

const webAppSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title.replace(/｜TaiCalc$/, '').replace(/\｜.*$/, ''),
  "description": description,
  "url": `https://taicalc.com/tools/${Astro.url.pathname.split('/').pop()}`,
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "TWD"
  },
  "browserRequirements": "Requires JavaScript",
  "softwareVersion": "2026",
  "keywords": keywords || "台灣,財務計算,免費工具"
});

const currentPath = normalizeToolPath(Astro.url.pathname);
const fallbackTitle = title.replace(/｜TaiCalc$/, '').replace(/\｜.*$/, '');
const cleanTitle = fallbackTitle;
const currentTool = getToolByHref(currentPath) ?? {
  href: currentPath,
  label: fallbackTitle,
  desc: description,
  category,
};
const currentToolJson = JSON.stringify(currentTool);
const relatedTools = getRelatedTools(currentPath);
---

<Layout title={title} description={description} keywords={keywords}>
    {faqSchema && <script type="application/ld+json" set:html={faqSchema} slot="head" />}
    <script type="application/ld+json" set:html={webAppSchema} slot="head" />
    <div class="max-w-6xl mx-auto px-4 md:px-0">
        <header class="pt-6 pb-6">
            <div class="tool-hero-panel hero-sheen relative overflow-hidden">
                <div class="relative z-10">
                    <div class="flex items-center gap-2 mb-3">
                        <a href="/" class="inline-flex items-center gap-1.5 text-xs text-ink-400 hover:text-ink-700 transition-colors group">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform">
                                <path d="M19 12H5M12 19l-7-7 7-7"/>
                            </svg>
                            所有工具
                        </a>
                        <span class="text-ink-300">/</span>
                        <span class="text-xs text-ink-400">{category}</span>
                    </div>
                    <div class="flex flex-wrap items-center gap-2 mb-4">
                        <div class="data-pill">{kicker}</div>
                        <span class="surface-badge">資料 {dataYear}</span>
                    </div>
                    <h1 class="text-2xl md:text-4xl font-semibold text-ink-700 mb-3">{cleanTitle}</h1>
                    <p class="text-sm md:text-base text-ink-500 leading-7 max-w-xl">{description}</p>
                    <div class="mt-5 flex flex-wrap gap-2">
                        <a href="#calculator-panel" class="action-link" data-sfx="accent">開始試算</a>
                        <button
                            id="favorite-tool-toggle"
                            type="button"
                            class="action-link"
                            data-tool={currentToolJson}
                        >
                            加入常用
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <main id="calculator-panel" class="mb-10 max-w-3xl">
            <div class="section-heading mb-5">
                <div>
                    <h2 class="text-xl font-semibold text-ink-700">輸入條件</h2>
                </div>
                <p class="section-heading-copy">先得到答案。</p>
            </div>
            <slot name="tool" />
        </main>

        <section class="max-w-3xl mb-12">
            <details class="rounded-2xl border border-paper-300 bg-paper-200 p-5">
                <summary class="cursor-pointer text-sm font-semibold text-ink-700">來源與 AI 邊界</summary>
                <div class="mt-5 grid gap-4 md:grid-cols-3">
                    <div class="meta-tile">
                        <p class="meta-tile-label">Version</p>
                        <p class="meta-tile-value">{dataVersion}</p>
                    </div>
                    <div class="meta-tile">
                        <p class="meta-tile-label">Data Year</p>
                        <p class="meta-tile-value">{dataYear}</p>
                    </div>
                    <div class="meta-tile">
                        <p class="meta-tile-label">Updated</p>
                        <p class="meta-tile-value">{lastUpdated}</p>
                    </div>
                </div>
                <div class="mt-5 grid gap-5 md:grid-cols-[1.1fr_0.9fr]">
                    <div>
                        <p class="text-sm font-medium text-ink-700">官方來源</p>
                        <ul class="mt-3 grid gap-2">
                            {sources.map((source) => (
                                <li>
                                    <a href={source.href} target="_blank" rel="noopener noreferrer" class="action-link w-full justify-between !text-xs">
                                        <span>{source.label}</span>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-ink-700">AI 邊界</p>
                        <ul class="signal-list mt-3">
                            <li><span class="signal-dot"></span><span>頁面結果為準。</span></li>
                            <li><span class="signal-dot"></span><span>不做投資建議。</span></li>
                            <li><span class="signal-dot"></span><span>不輸入個資。</span></li>
                        </ul>
                    </div>
                </div>
            </details>
        </section>

        <article id="guide-panel" class="prose prose-gray max-w-3xl mb-16 text-sm">
            <div class="section-heading not-prose mb-6 border-t border-paper-300 pt-10">
                <div>
                    <p class="text-[11px] font-semibold text-brand uppercase tracking-[0.2em]">Guide</p>
                    <h2 class="text-xl font-semibold text-ink-700 mt-2">規則說明</h2>
                </div>
                <p class="section-heading-copy">需要時再讀。</p>
            </div>
            <slot name="article" />
        </article>

        {faqs.length > 0 && (
            <section class="mb-16 max-w-3xl">
                <div class="flex items-center gap-3 mb-6 border-t border-paper-300 pt-10">
                    <div class="w-8 h-8 rounded-lg bg-brand-50 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-500">
                            <circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/>
                        </svg>
                    </div>
                    <h2 class="text-base font-semibold text-ink-700">常見問題</h2>
                </div>
                <dl class="space-y-3">
                    {faqs.map((faq) => (
                        <details class="group bg-paper-200 border border-paper-300 rounded-xl overflow-hidden hover:border-brand-200 transition-colors">
                            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none select-none">
                                <dt class="text-sm font-medium text-ink-700 pr-4">{faq.q}</dt>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                     class="text-ink-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180">
                                    <path d="m6 9 6 6 6-6"/>
                                </svg>
                            </summary>
                            <dd class="px-5 pb-4 text-sm text-ink-500 leading-relaxed border-t border-paper-300/60 pt-3">{faq.a}</dd>
                        </details>
                    ))}
                </dl>
            </section>
        )}

        <section class="border-t border-paper-300 pt-10 mb-16 max-w-3xl">
            <div class="section-heading mb-6">
                <div>
                    <h3 class="text-sm font-medium text-ink-400 uppercase tracking-widest">更多工具</h3>
                    <p class="text-lg font-semibold text-ink-700 mt-2">下一步</p>
                </div>
                <p class="section-heading-copy">直接接續。</p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {relatedTools.map((tool) => (
                    <a href={tool.href} class="flex items-center justify-between p-4 rounded-2xl bg-paper-200 border border-paper-300 hover:border-brand-200 hover:shadow-card transition-all group">
                        <div>
                            <div class="text-sm font-medium text-ink-700 transition-colors">{tool.label}</div>
                            <div class="text-xs text-ink-400 mt-0.5">{tool.desc}</div>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-300 group-hover:text-brand-500 group-hover:translate-x-0.5 transition-all flex-shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                ))}
            </div>
        </section>
    </div>
</Layout>

<script>
const favoriteToggle = document.getElementById('favorite-tool-toggle') as HTMLButtonElement | null;

if (favoriteToggle) {
    const storageKey = 'taicalc-tool-state-v1';
    const currentTool = JSON.parse(favoriteToggle.dataset.tool || '{}');

    const readState = () => {
        try {
            const raw = localStorage.getItem(storageKey);
            return raw ? JSON.parse(raw) : { recent: [], pinned: [] };
        } catch {
            return { recent: [], pinned: [] };
        }
    };

    const writeState = (state: { recent: any[]; pinned: any[] }) => {
        localStorage.setItem(storageKey, JSON.stringify(state));
    };
    const track = (window as any).taicalcTrackEvent as ((eventName: string, params?: Record<string, string | number | boolean>) => void) | undefined;

    const syncButton = () => {
        const state = readState();
        const isPinned = state.pinned.some((item: { href: string }) => item.href === currentTool.href);
        favoriteToggle.textContent = isPinned ? '已加入常用' : '加入常用';
        favoriteToggle.classList.toggle('border-brand', isPinned);
        favoriteToggle.classList.toggle('text-ink-700', isPinned);
    };

    const trackVisit = () => {
        const state = readState();
        const timestamp = new Date().toISOString();
        const nextItem = { ...currentTool, lastVisitedAt: timestamp };
        state.recent = [nextItem, ...state.recent.filter((item: { href: string }) => item.href !== currentTool.href)].slice(0, 6);
        writeState(state);
    };

    favoriteToggle.addEventListener('click', () => {
        const state = readState();
        const exists = state.pinned.some((item: { href: string }) => item.href === currentTool.href);
        state.pinned = exists
            ? state.pinned.filter((item: { href: string }) => item.href !== currentTool.href)
            : [{ ...currentTool, pinnedAt: new Date().toISOString() }, ...state.pinned].slice(0, 6);
        writeState(state);
        syncButton();
    });

    trackVisit();
    syncButton();

    const calculatorPanel = document.getElementById('calculator-panel');
    if (calculatorPanel) {
        const toolPath = window.location.pathname;
        let started = false;
        let lastCompletionAt = 0;
        let lastResultSignature = '';

        const markStarted = () => {
            if (started) return;
            started = true;
            track?.('input_start', {
                tool_path: toolPath,
            });
        };

        const readResultSignature = () => {
            const blocks = Array.from(
                calculatorPanel.querySelectorAll<HTMLElement>('.result-card, .result-main-card, .result-value, [class*="result"]')
            );
            const values = blocks
                .map((block) => block.textContent?.replace(/\s+/g, ' ').trim() ?? '')
                .filter((text) => /[\d$%NT]/.test(text))
                .slice(0, 8);
            return values.join('|').slice(0, 360);
        };

        const markCompleted = () => {
            if (!started) return;
            const now = Date.now();
            if (now - lastCompletionAt < 1200) return;
            const signature = readResultSignature();
            if (!signature || signature === lastResultSignature) return;
            lastResultSignature = signature;
            lastCompletionAt = now;
            track?.('calculation_complete', {
                tool_path: toolPath,
            });
        };

        calculatorPanel.addEventListener('input', (event) => {
            const target = event.target as HTMLElement | null;
            if (!(target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement || target instanceof HTMLSelectElement)) return;
            markStarted();
        });

        calculatorPanel.addEventListener('change', (event) => {
            const target = event.target as HTMLElement | null;
            if (!(target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement || target instanceof HTMLSelectElement)) return;
            markStarted();
            window.setTimeout(markCompleted, 50);
        });

        calculatorPanel.addEventListener('click', (event) => {
            const target = event.target as HTMLElement | null;
            const button = target?.closest('button');
            if (!button) return;
            const label = button.textContent?.trim() ?? '';
            if (/計算|試算|更新|比較|分析|開始|送出/.test(label)) {
                markStarted();
                window.setTimeout(markCompleted, 50);
            }
        });

        const observer = new MutationObserver(() => {
            window.setTimeout(markCompleted, 80);
        });
        observer.observe(calculatorPanel, { subtree: true, childList: true, characterData: true });
    }
}
</script>
