---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  category?: string;
}

const { title, description, category = "工具" } = Astro.props;
---

<Layout title={title} description={description}>
    <div class="max-w-3xl mx-auto px-4 md:px-0">
        <!-- Compact Tool Header -->
        <header class="pt-6 pb-8">
            <div class="flex items-center gap-2 mb-3">
                <a href="/" class="inline-flex items-center gap-1.5 text-xs text-ink-400 hover:text-ink-700 transition-colors group">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform">
                        <path d="M19 12H5M12 19l-7-7 7-7"/>
                    </svg>
                    所有工具
                </a>
                <span class="text-ink-300">/</span>
                <span class="text-xs text-ink-400">{category}</span>
            </div>
            <h1 class="text-2xl md:text-3xl font-semibold text-ink-700 tracking-tight mb-2">{title.replace(/｜TaiCalc$/, '').replace(/\｜.*$/, '')}</h1>
            <p class="text-sm text-ink-400 leading-relaxed max-w-2xl">{description}</p>
        </header>

        <!-- Tool: Calculator Component -->
        <main class="mb-16">
            <slot name="tool" />
        </main>

        <!-- Article: SEO Content -->
        <article class="prose prose-gray max-w-none mb-16 text-sm">
            <slot name="article" />
        </article>

        <!-- Cross-Linking: Related Tools -->
        <section class="border-t border-paper-300 pt-10 mb-16">
            <h3 class="text-sm font-medium text-ink-400 uppercase tracking-widest mb-6">更多工具</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                 <a href="/tools/salary-calculator" class="flex items-center justify-between p-4 rounded-xl border border-paper-300 hover:border-azure hover:bg-azure-50 transition-all group">
                    <div>
                        <div class="text-sm font-medium text-ink-700 group-hover:text-azure-700 transition-colors">薪資實拿試算</div>
                        <div class="text-xs text-ink-400 mt-0.5">扣除勞健保後實際領多少？</div>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-300 group-hover:text-azure group-hover:translate-x-0.5 transition-all flex-shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
                <a href="/tools/mortgage-calculator" class="flex items-center justify-between p-4 rounded-xl border border-paper-300 hover:border-azure hover:bg-azure-50 transition-all group">
                    <div>
                        <div class="text-sm font-medium text-ink-700 group-hover:text-azure-700 transition-colors">房貸試算</div>
                        <div class="text-xs text-ink-400 mt-0.5">新青安、寬限期與還款試算。</div>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-300 group-hover:text-azure group-hover:translate-x-0.5 transition-all flex-shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
                <a href="/tools/fire-calculator" class="flex items-center justify-between p-4 rounded-xl border border-paper-300 hover:border-azure hover:bg-azure-50 transition-all group">
                    <div>
                        <div class="text-sm font-medium text-ink-700 group-hover:text-azure-700 transition-colors">FIRE 退休規劃</div>
                        <div class="text-xs text-ink-400 mt-0.5">計算你需要多少錢才能退休？</div>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-300 group-hover:text-azure group-hover:translate-x-0.5 transition-all flex-shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
                <a href="/tools/labor-pension-calculator" class="flex items-center justify-between p-4 rounded-xl border border-paper-300 hover:border-azure hover:bg-azure-50 transition-all group">
                    <div>
                        <div class="text-sm font-medium text-ink-700 group-hover:text-azure-700 transition-colors">勞退試算</div>
                        <div class="text-xs text-ink-400 mt-0.5">複利滾存與節稅效益分析。</div>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-300 group-hover:text-azure group-hover:translate-x-0.5 transition-all flex-shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
            </div>
        </section>
    </div>
</Layout>
