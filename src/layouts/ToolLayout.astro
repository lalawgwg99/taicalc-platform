---
import Layout from './Layout.astro';
import { platformGovernance, type SourceLink } from '../data/regulatoryMetadata';
import { toolCatalogMap } from '../data/toolCatalog';

interface Props {
  title: string;
  description: string;
  category?: string;
  faqs?: { q: string; a: string }[];
  keywords?: string;
  kicker?: string;
  dataVersion?: string;
  dataYear?: string;
  lastUpdated?: string;
  sources?: SourceLink[];
}

const {
  title,
  description,
  category = "工具",
  faqs = [],
  keywords,
  kicker = "把複雜規則轉成可操作的答案",
  dataVersion = platformGovernance.version,
  dataYear = platformGovernance.dataYear,
  lastUpdated = platformGovernance.updatedAt,
  sources = platformGovernance.sources
} = Astro.props;

const faqSchema = faqs.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a,
      "dateCreated": new Date().toISOString().split('T')[0]
    }
  }))
}) : null;

const webAppSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title.replace(/｜TaiCalc$/, '').replace(/\｜.*$/, ''),
  "description": description,
  "url": `https://taicalc.com/tools/${Astro.url.pathname.split('/').pop()}`,
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "TWD"
  },
  "browserRequirements": "Requires JavaScript",
  "softwareVersion": "2026",
  "keywords": keywords || "台灣,財務計算,免費工具"
});

const currentPath = Astro.url.pathname;
const fallbackTitle = title.replace(/｜TaiCalc$/, '').replace(/\｜.*$/, '');
const currentTool = toolCatalogMap[currentPath] ?? {
  href: currentPath,
  label: fallbackTitle,
  desc: description,
  category,
};
const currentToolJson = JSON.stringify(currentTool);
---

<Layout title={title} description={description} keywords={keywords}>
    {faqSchema && <script type="application/ld+json" set:html={faqSchema} slot="head" />}
    <script type="application/ld+json" set:html={webAppSchema} slot="head" />
    <div class="max-w-6xl mx-auto px-4 md:px-0">
        <header class="pt-6 pb-8">
            <div class="tool-hero-shell">
                <div class="tool-hero-panel hero-sheen relative overflow-hidden">
                    <div class="relative z-10">
                        <div class="flex items-center gap-2 mb-3">
                            <a href="/" class="inline-flex items-center gap-1.5 text-xs text-ink-400 hover:text-ink-700 transition-colors group">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform">
                                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                                </svg>
                                所有工具
                            </a>
                            <span class="text-ink-300">/</span>
                            <span class="text-xs text-ink-400">{category}</span>
                        </div>
                        <div class="data-pill mb-4">{kicker}</div>
                        <h1 class="text-2xl md:text-4xl font-semibold text-ink-700 tracking-tight mb-3">{title.replace(/｜TaiCalc$/, '').replace(/\｜.*$/, '')}</h1>
                        <p class="text-sm md:text-base text-ink-400 leading-relaxed max-w-2xl">{description}</p>
                        <div class="mt-5 flex flex-wrap gap-2">
                            <span class="data-pill">本地計算</span>
                            <span class="data-pill">結果可立即行動</span>
                            <span class="data-pill">免費使用</span>
                        </div>
                    </div>
                </div>

                <aside class="tool-hero-panel">
                    <slot name="heroAside">
                        <div class="space-y-4">
                            <div>
                                <p class="text-[11px] font-semibold text-brand uppercase tracking-[0.2em]">快速開始</p>
                                <h2 class="text-lg font-semibold text-ink-700 mt-2">先輸入你眼前的問題</h2>
                                <p class="text-sm text-ink-400 mt-2 leading-relaxed">這頁的設計不是為了看懂規則，而是讓你快速做決定。</p>
                            </div>
                            <div class="grid gap-2">
                                <div class="rounded-2xl bg-paper-100 border border-paper-300 p-4">
                                    <p class="text-xs text-ink-400">最適合</p>
                                    <p class="text-sm font-medium text-ink-700 mt-1">第一次試算、轉職比較、快速確認結果</p>
                                </div>
                                <div class="rounded-2xl bg-paper-100 border border-paper-300 p-4">
                                    <p class="text-xs text-ink-400">建議順序</p>
                                    <p class="text-sm font-medium text-ink-700 mt-1">輸入數字 → 看結果卡 → 再讀下方說明</p>
                                </div>
                            </div>
                        </div>
                    </slot>
                </aside>
            </div>
        </header>

        <section class="max-w-3xl mb-10 grid gap-3">
            <div class="rounded-2xl border border-paper-300 bg-paper-200 p-5">
                <div class="flex flex-wrap gap-2 text-xs">
                    <span class="data-pill">版本：{dataVersion}</span>
                    <span class="data-pill">年度：{dataYear}</span>
                    <span class="data-pill">更新：{lastUpdated}</span>
                </div>
                <p class="text-xs text-ink-400 mt-3">資料可追溯到官方來源，若政府公告變動，版本號會同步更新。</p>
                <ul class="mt-3 space-y-1.5">
                    {sources.map((source) => (
                        <li>
                            <a
                                href={source.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-xs text-ink-500 hover:text-brand transition-colors"
                            >
                                {source.label}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

            <div class="rounded-2xl border border-paper-300 bg-paper-200 p-4 text-xs text-ink-500 leading-relaxed">
                AI 僅提供工具導引與計算邏輯解釋，不替代本頁實際計算結果，不提供投資建議，也不處理個人敏感資料。
            </div>

            <div class="rounded-2xl border border-paper-300 bg-paper-200 p-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <p class="text-sm font-medium text-ink-700">把這頁加入常用工具</p>
                    <p class="text-xs text-ink-400 mt-1">下次回首頁可以直接從「最近使用」或「常用工具」繼續。</p>
                </div>
                <button
                    id="favorite-tool-toggle"
                    type="button"
                    class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl border border-paper-300 bg-paper-100 text-sm font-medium text-ink-600 hover:border-brand hover:text-ink-700 transition-colors"
                    data-tool={currentToolJson}
                >
                    加入常用
                </button>
            </div>
        </section>

        <main class="mb-16 max-w-3xl">
            <slot name="tool" />
        </main>

        <article class="prose prose-gray max-w-3xl mb-16 text-sm">
            <slot name="article" />
        </article>

        {faqs.length > 0 && (
            <section class="mb-16 max-w-3xl">
                <div class="flex items-center gap-3 mb-6 border-t border-paper-300 pt-10">
                    <div class="w-8 h-8 rounded-lg bg-brand-50 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-500">
                            <circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/>
                        </svg>
                    </div>
                    <h2 class="text-base font-semibold text-ink-700">常見問題</h2>
                </div>
                <dl class="space-y-3">
                    {faqs.map((faq) => (
                        <details class="group bg-paper-200 border border-paper-300 rounded-xl overflow-hidden hover:border-brand-200 transition-colors">
                            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none select-none">
                                <dt class="text-sm font-medium text-ink-700 pr-4">{faq.q}</dt>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                     class="text-ink-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180">
                                    <path d="m6 9 6 6 6-6"/>
                                </svg>
                            </summary>
                            <dd class="px-5 pb-4 text-sm text-ink-500 leading-relaxed border-t border-paper-300/60 pt-3">{faq.a}</dd>
                        </details>
                    ))}
                </dl>
            </section>
        )}

        <section class="border-t border-paper-300 pt-10 mb-16 max-w-3xl">
            <h3 class="text-sm font-medium text-ink-400 uppercase tracking-widest mb-6">更多工具</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                 <a href="/tools/salary-calculator" class="flex items-center justify-between p-4 rounded-xl bg-paper-200 border border-paper-300 hover:border-brand-200 hover:shadow-card transition-all group">
                    <div>
                        <div class="text-sm font-medium text-ink-700 transition-colors">薪資實拿試算</div>
                        <div class="text-xs text-ink-400 mt-0.5">扣除勞健保後實際領多少？</div>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-300 group-hover:text-brand-500 group-hover:translate-x-0.5 transition-all flex-shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
                <a href="/tools/mortgage-calculator" class="flex items-center justify-between p-4 rounded-xl bg-paper-200 border border-paper-300 hover:border-brand-200 hover:shadow-card transition-all group">
                    <div>
                        <div class="text-sm font-medium text-ink-700 transition-colors">房貸試算</div>
                        <div class="text-xs text-ink-400 mt-0.5">新青安、寬限期與還款試算。</div>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-300 group-hover:text-brand-500 group-hover:translate-x-0.5 transition-all flex-shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
                <a href="/tools/fire-calculator" class="flex items-center justify-between p-4 rounded-xl bg-paper-200 border border-paper-300 hover:border-brand-200 hover:shadow-card transition-all group">
                    <div>
                        <div class="text-sm font-medium text-ink-700 transition-colors">FIRE 退休規劃</div>
                        <div class="text-xs text-ink-400 mt-0.5">計算你需要多少錢才能退休？</div>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-300 group-hover:text-brand-500 group-hover:translate-x-0.5 transition-all flex-shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
                <a href="/tools/labor-pension-calculator" class="flex items-center justify-between p-4 rounded-xl bg-paper-200 border border-paper-300 hover:border-brand-200 hover:shadow-card transition-all group">
                    <div>
                        <div class="text-sm font-medium text-ink-700 transition-colors">勞退試算</div>
                        <div class="text-xs text-ink-400 mt-0.5">複利滾存與節稅效益分析。</div>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-300 group-hover:text-brand-500 group-hover:translate-x-0.5 transition-all flex-shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
            </div>
        </section>
    </div>
</Layout>

<script>
const favoriteToggle = document.getElementById('favorite-tool-toggle') as HTMLButtonElement | null;

if (favoriteToggle) {
    const storageKey = 'taicalc-tool-state-v1';
    const currentTool = JSON.parse(favoriteToggle.dataset.tool || '{}');

    const readState = () => {
        try {
            const raw = localStorage.getItem(storageKey);
            return raw ? JSON.parse(raw) : { recent: [], pinned: [] };
        } catch {
            return { recent: [], pinned: [] };
        }
    };

    const writeState = (state: { recent: any[]; pinned: any[] }) => {
        localStorage.setItem(storageKey, JSON.stringify(state));
    };

    const syncButton = () => {
        const state = readState();
        const isPinned = state.pinned.some((item: { href: string }) => item.href === currentTool.href);
        favoriteToggle.textContent = isPinned ? '已加入常用' : '加入常用';
        favoriteToggle.classList.toggle('border-brand', isPinned);
        favoriteToggle.classList.toggle('text-ink-700', isPinned);
    };

    const trackVisit = () => {
        const state = readState();
        const timestamp = new Date().toISOString();
        const nextItem = { ...currentTool, lastVisitedAt: timestamp };
        state.recent = [nextItem, ...state.recent.filter((item: { href: string }) => item.href !== currentTool.href)].slice(0, 6);
        writeState(state);
    };

    favoriteToggle.addEventListener('click', () => {
        const state = readState();
        const exists = state.pinned.some((item: { href: string }) => item.href === currentTool.href);
        state.pinned = exists
            ? state.pinned.filter((item: { href: string }) => item.href !== currentTool.href)
            : [{ ...currentTool, pinnedAt: new Date().toISOString() }, ...state.pinned].slice(0, 6);
        writeState(state);
        syncButton();
    });

    trackVisit();
    syncButton();
}
</script>
