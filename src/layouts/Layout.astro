---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
    description?: string;
    fullWidth?: boolean;
    hideNav?: boolean;
    hideFooter?: boolean;
    ogImage?: string;
    keywords?: string;
    type?: string;
}

const {
    title,
    description = "TaiCalc 專業財務計算平台｜台灣人專用免費線上工具。2026 最新薪資稅額、勞健保級距、新青安房貸試算、FIRE 退休規劃、股票當沖手續費計算。完全本地運算，資料不外傳。",
    fullWidth = false,
    hideNav = false,
    hideFooter = false,
    ogImage = "https://taicalc.com/og-image.png",
    keywords = "薪資計算機,房貸試算,所得稅,2026新制,勞健保,FIRE退休,當沖手續費,台灣財務計算機,免費線上工具",
    type = "website"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = "TaiCalc 財務計算平台";
const fullTitle = title.includes("TaiCalc") ? title : `${title} | TaiCalc`;
---

<!DOCTYPE html>
<html lang="zh-TW">
	<head>
		<meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="keywords" content={keywords} />
        <meta name="author" content="TaiCalc" />
        <meta name="theme-color" content="#0F1012" />
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
        <meta name="googlebot" content="index, follow" />
        <meta name="language" content="Chinese" />
        <meta name="revisit-after" content="7 days" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
        <link rel="canonical" href={canonicalURL} />
        <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />

        <!-- Open Graph / Social -->
        <meta property="og:type" content={type} />
        <meta property="og:site_name" content={siteName} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={fullTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:locale" content="zh_TW" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@taicalc" />
        <meta name="twitter:title" content={fullTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />

		<title>{fullTitle}</title>

        <!-- JSON-LD Structured Data -->
        <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": siteName,
            "alternateName": "台灣財務計算機",
            "url": "https://taicalc.com",
            "description": description,
            "keywords": keywords,
            "inLanguage": "zh-TW",
            "potentialAction": {
                "@type": "SearchAction",
                "target": {
                    "@type": "EntryPoint",
                    "urlTemplate": "https://taicalc.com/?search={search_term_string}"
                },
                "query-input": "required name=search_term_string"
            }
        })} />

        <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Organization",
            "name": "TaiCalc",
            "url": "https://taicalc.com",
            "logo": "https://taicalc.com/favicon.svg",
            "description": "專為台灣人設計的免費財務計算機平台",
            "sameAs": [
                "https://github.com/lalawgwg99/taicalc-platform"
            ],
            "contactPoint": {
                "@type": "ContactPoint",
                "email": "service@taicalc.com",
                "contactType": "customer service"
            }
        })} />

        <!-- Fonts — Space Grotesk + IBM Plex Sans -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=Source+Serif+4:wght@400;600&display=swap" rel="stylesheet" />

        <!-- Google Analytics (GA4) -->
        { import.meta.env.PUBLIC_GA_ID && (
            <>
                <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`}></script>
                <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA_ID }}>
                    window.dataLayer = window.dataLayer || [];
                    function gtag(){dataLayer.push(arguments);}
                    gtag('js', new Date());
                    gtag('config', gaId);
                </script>
            </>
        )}
	</head>
    <body class="bg-paper-100 text-ink-700 min-h-screen flex flex-col font-sans antialiased selection:bg-brand selection:text-paper-50">
        { !fullWidth ? (
            <div class="max-w-6xl mx-auto px-4 md:px-6 w-full flex-grow flex flex-col">
                { !hideNav && <Navbar /> }
                <main class="flex-grow">
                    <slot />
                </main>
                { !hideFooter && <Footer /> }
            </div>
        ) : (
            <div class="w-full flex-grow flex flex-col">
                { !hideNav && <div class="max-w-6xl mx-auto px-4 md:px-6 w-full"><Navbar /></div> }
                <main class="flex-grow">
                    <slot />
                </main>
                { !hideFooter && <div class="max-w-6xl mx-auto px-4 md:px-6 w-full"><Footer /></div> }
            </div>
        )}

    <script>
    // ── Analytics Bridge (GA4) ─────────────────────────────────────
    (function () {
        type TrackParams = Record<string, string | number | boolean>;
        type TrackFn = (eventName: string, params?: TrackParams) => void;

        const track: TrackFn = (eventName, params = {}) => {
            if (typeof window === 'undefined') return;
            try {
                const payload = { page_path: window.location.pathname, ...params };
                const gtagFn = (window as any).gtag;
                if (typeof gtagFn === 'function') {
                    gtagFn('event', eventName, payload);
                    return;
                }
                const dataLayer = (window as any).dataLayer;
                if (Array.isArray(dataLayer)) {
                    dataLayer.push({ event: eventName, ...payload });
                }
            } catch (_) {
                // Ignore analytics errors to avoid affecting user flows.
            }
        };

        (window as any).taicalcTrackEvent = track;

        document.addEventListener('click', (event) => {
            const target = event.target as HTMLElement | null;
            const anchor = target?.closest('a[href]') as HTMLAnchorElement | null;
            if (!anchor) return;
            const href = anchor.getAttribute('href') ?? '';
            if (!href.startsWith('/tools/')) return;
            track('tool_click', {
                tool_path: href,
                source_path: window.location.pathname,
                label: anchor.textContent?.trim() ?? '',
            });
        });

        document.addEventListener('click', (event) => {
            const target = event.target as HTMLElement | null;
            const button = target?.closest('button');
            if (!button) return;
            const label = button.textContent?.trim() ?? '';
            if (!/複製|copy/i.test(label)) return;
            track('result_copy', {
                source_path: window.location.pathname,
                label,
            });
        });

        const originalWriteText = navigator.clipboard?.writeText?.bind(navigator.clipboard);
        if (originalWriteText) {
            try {
                navigator.clipboard.writeText = async (text: string) => {
                    track('result_copy', {
                        char_count: text.length,
                    });
                    return originalWriteText(text);
                };
            } catch (_) {
                // Some browsers block overriding clipboard APIs.
            }
        }
    })();
    </script>

    <!-- ── 浮動 AI 助理 (FAB) ─────────────────────────────────────── -->
    <div id="taicalc-fab" class="support-fab">
        <div id="fab-panel" class="support-panel animate-fade-in-up">
            <div class="support-panel-shell">
                <div class="support-header">
                    <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <span class="support-status">AI 支援</span>
                            <div class="mt-3 flex items-start gap-3">
                                <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-paper-300/80 bg-paper-100/80 text-lg shadow-card">
                                    算
                                </div>
                                <div class="min-w-0">
                                    <div class="flex items-center gap-2">
                                        <p class="text-sm font-semibold text-ink-700">TaiCalc AI 助理</p>
                                        <span class="rounded-full border border-paper-300/80 bg-paper-100/80 px-2 py-0.5 text-[10px] text-ink-500">算盤</span>
                                    </div>
                                    <p class="mt-1 text-xs leading-6 text-ink-500">選工具。看結果。少走彎路。</p>
                                </div>
                            </div>
                        </div>
                        <button id="fab-close" aria-label="關閉" data-sfx="tap"
                            class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-xl text-lg leading-none text-ink-400 transition-colors hover:bg-paper-100 hover:text-ink-700">
                            ×
                        </button>
                    </div>

                    <div class="mt-4 grid grid-cols-2 gap-2 text-[11px]">
                        <div class="support-bubble-note">下一步</div>
                        <div class="support-bubble-note">不收個資</div>
                    </div>

                    <div class="support-quick-asks mt-4">
                        <button type="button" class="support-chip" data-fab-prompt="我拿到 Offer，月薪 5 萬，先算哪個？">Offer 實拿</button>
                        <button type="button" class="support-chip" data-fab-prompt="我要五月報稅，先看哪個工具？">五月報稅</button>
                        <button type="button" class="support-chip" data-fab-prompt="準備買房，先算頭期款還是月付金？">準備買房</button>
                    </div>
                </div>

                <div id="fab-messages" class="support-messages">
                    <div class="support-bubble-ai">
                        說情境，我幫你選工具。
                    </div>
                </div>

                <div class="support-input-shell">
                    <div class="support-input-row">
                        <textarea id="fab-input" rows="1"
                            placeholder="例如：月薪 5 萬先算哪個？"
                            class="support-input"></textarea>
                        <button id="fab-send" data-sfx="accent"
                            class="inline-flex h-[46px] shrink-0 items-center justify-center rounded-2xl bg-gradient-to-r from-brand-500 to-azure-500 px-4 text-sm font-semibold text-paper-50 transition-all hover:brightness-110 disabled:opacity-40">
                            送出
                        </button>
                    </div>
                    <p class="mt-3 text-[10px] leading-5 text-ink-400">只導引。不輸入個資。</p>
                </div>
            </div>
        </div>

        <button id="fab-toggle" data-sfx="tap" class="support-toggle">
            <span class="support-toggle-badge">
                <svg id="fab-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
            </span>
            <span class="support-toggle-caption">
                <span>AI Support</span>
                <span id="fab-label">AI 幫我算</span>
            </span>
        </button>
    </div>

    <script>
    // ── TaiCalc 浮動 AI 助理 ─────────────────────────────────────────
    (function () {
        const fab      = document.getElementById('taicalc-fab');
        const toggle   = document.getElementById('fab-toggle');
        const panel    = document.getElementById('fab-panel');
        const closeBtn = document.getElementById('fab-close');
        const input    = document.getElementById('fab-input') as HTMLTextAreaElement | null;
        const sendBtn  = document.getElementById('fab-send') as HTMLButtonElement | null;
        const msgs     = document.getElementById('fab-messages');
        const quickPrompts = Array.from(document.querySelectorAll<HTMLElement>('[data-fab-prompt]'));
        if (!toggle || !panel) return;

        const openPanel = () => {
            panel.classList.remove('hidden');
            (window as any).taicalcTrackEvent?.('ai_open', {
                trigger: 'fab_toggle',
            });
            input?.focus();
        };
        const closePanel = () => panel.classList.add('hidden');

        toggle.addEventListener('click', () =>
            panel.classList.contains('hidden') ? openPanel() : closePanel()
        );
        closeBtn?.addEventListener('click', closePanel);

        // 點外部關閉
        document.addEventListener('click', (e) => {
            if (!fab?.contains(e.target as Node)) closePanel();
        });

        const syncComposerHeight = () => {
            if (!input) return;
            input.style.height = 'auto';
            input.style.height = `${Math.min(input.scrollHeight, 120)}px`;
        };

        const addMsg = (role: 'user' | 'ai', text: string) => {
            const d = document.createElement('div');
            d.className = role === 'user'
                ? 'support-bubble-user'
                : 'support-bubble-ai';
            d.textContent = text;
            msgs?.appendChild(d);
            msgs?.scrollTo({ top: msgs.scrollHeight, behavior: 'smooth' });
            return d;
        };

        let history: { role: string; content: string }[] = [];
        const piiPattern = /([A-Z][12]\d{8}|09\d{8}|[\\w.+-]+@[\\w.-]+\\.[A-Za-z]{2,}|\\b\\d{16}\\b)/i;

        const send = async () => {
            const q = input?.value.trim();
            if (!q || sendBtn?.disabled) return;

            if (piiPattern.test(q)) {
                addMsg('ai', '請先移除身分證、電話、Email 或卡號。');
                if (input) input.value = '';
                syncComposerHeight();
                input?.focus();
                return;
            }

            addMsg('user', q);
            history.push({ role: 'user', content: q });
            if (input) input.value = '';
            syncComposerHeight();
            if (sendBtn) sendBtn.disabled = true;

            const thinking = addMsg('ai', '整理中…');
            thinking.classList.add('animate-pulse');

            try {
                const res = await fetch('/api/taicalc-chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        history: history.slice(-6),
                        userQuery: q,
                    }),
                });
                thinking.remove();
                const data = res.ok ? await res.json() : null;
                const reply = data?.text ?? '🔌 服務暫時無法使用，請稍後再試。';
                addMsg('ai', reply);
                history.push({ role: 'assistant', content: reply });
            } catch (_) {
                thinking.remove();
                addMsg('ai', '🌐 連線失敗，請確認網路狀態。');
            }

            if (sendBtn) sendBtn.disabled = false;
            input?.focus();
        };

        sendBtn?.addEventListener('click', send);
        input?.addEventListener('input', syncComposerHeight);
        input?.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
        });

        quickPrompts.forEach((button) => {
            button.addEventListener('click', () => {
                const prompt = button.getAttribute('data-fab-prompt');
                if (!prompt || !input) return;
                openPanel();
                input.value = prompt;
                syncComposerHeight();
                input.focus();
            });
        });

        syncComposerHeight();
    })();
    </script>

    <script>
    // ── Hermes SFX + Reveal ────────────────────────────────────────
    (function () {
        const soundKey = 'taicalc-sfx';
        const toggle = document.getElementById('sound-toggle') as HTMLButtonElement | null;
        const toggleMobile = document.getElementById('sound-toggle-mobile') as HTMLButtonElement | null;
        const AudioCtx = window.AudioContext || (window as any).webkitAudioContext;
        let ctx: AudioContext | null = null;
        let enabled = localStorage.getItem(soundKey) === 'on';

        const syncToggle = (el: HTMLButtonElement | null) => {
            if (!el) return;
            el.classList.toggle('is-on', enabled);
            el.setAttribute('aria-pressed', enabled ? 'true' : 'false');
            el.textContent = enabled ? '音效 On' : '音效 Off';
        };

        const ensureCtx = () => {
            if (!AudioCtx) return null;
            if (!ctx) ctx = new AudioCtx();
            if (ctx.state === 'suspended') ctx.resume();
            return ctx;
        };

        const play = (type: 'tap' | 'accent' = 'tap', force = false) => {
            if (!enabled && !force) return;
            const audio = ensureCtx();
            if (!audio) return;
            const osc = audio.createOscillator();
            const gain = audio.createGain();
            const now = audio.currentTime;
            const freq = type === 'accent' ? 680 : 520;
            const dur = type === 'accent' ? 0.08 : 0.04;
            osc.type = 'sine';
            osc.frequency.setValueAtTime(freq, now);
            gain.gain.setValueAtTime(0.001, now);
            gain.gain.exponentialRampToValueAtTime(0.08, now + 0.01);
            gain.gain.exponentialRampToValueAtTime(0.001, now + dur);
            osc.connect(gain);
            gain.connect(audio.destination);
            osc.start(now);
            osc.stop(now + dur + 0.02);
        };

        const toggleSound = () => {
            enabled = !enabled;
            localStorage.setItem(soundKey, enabled ? 'on' : 'off');
            syncToggle(toggle);
            syncToggle(toggleMobile);
            play('accent', true);
        };

        syncToggle(toggle);
        syncToggle(toggleMobile);
        toggle?.addEventListener('click', toggleSound);
        toggleMobile?.addEventListener('click', toggleSound);

        document.addEventListener('click', (e) => {
            const el = (e.target as HTMLElement | null)?.closest('[data-sfx]');
            if (!el) return;
            const type = (el.getAttribute('data-sfx') as 'tap' | 'accent' | null) ?? 'tap';
            play(type);
        });

        const revealItems = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));
        if (!revealItems.length) return;
        if (!('IntersectionObserver' in window)) {
            revealItems.forEach(el => el.classList.add('is-visible'));
            return;
        }

        const observer = new IntersectionObserver((entries, obs) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    obs.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15 });

        revealItems.forEach(el => observer.observe(el));
    })();
    </script>

	</body>
</html>
