    {secondarySections.map((section, idx) => (
        <section class={`py-16 md:py-24 ${idx % 2 === 0 ? 'bg-paper-100 section-wash' : 'bg-white section-wash'}`}>
            <div class="max-w-6xl mx-auto px-4 md:px-6">
