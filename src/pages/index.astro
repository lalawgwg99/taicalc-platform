---
import Layout from '../layouts/Layout.astro';

const title = "TaiCalc 財務計算平台";
const description = "整合薪資、所得稅、房貸與退休規劃的財務計算平台。2026 最新費率，所有計算在本地執行，安全隱私。";

const allTools = [
    { href: "/tools/salary-calculator",       label: "薪資實拿計算",   desc: "月薪扣除勞健保後實領多少",     section: "薪資與稅務" },
    { href: "/tools/income-tax-calculator",    label: "綜合所得稅試算", desc: "標準vs列舉扣除，最省稅方案",   section: "薪資與稅務", isNew: true },
    { href: "/tools/insurance-calculator",     label: "勞健保計算",     desc: "費率級距與眷屬附保明細",       section: "薪資與稅務" },
    { href: "/tools/overtime-calculator",      label: "加班費試算",     desc: "平日、休息日、國定假日",       section: "薪資與稅務" },
    { href: "/tools/delivery-income-calculator", label: "外送收入計算", desc: "跑單淨收入與油費成本",         section: "薪資與稅務" },
    { href: "/tools/mortgage-calculator",      label: "房貸試算",       desc: "新青安、寬限期與提前還款",     section: "居住與房產" },
    { href: "/tools/rent-cost-calculator",     label: "租金解析",       desc: "租屋押金與真實月支出",         section: "居住與房產" },
    { href: "/tools/electricity-calculator",   label: "電費試算",       desc: "台電累進費率自動計算",         section: "居住與房產" },
    { href: "/tools/ac-installation-calculator", label: "冷氣評估",     desc: "安裝費與回本年限試算",         section: "居住與房產" },
    { href: "/tools/fire-calculator",          label: "FIRE 退休規劃",  desc: "複利效應與財務自由倒數",       section: "投資與退休" },
    { href: "/tools/labor-pension-calculator", label: "勞退試算",       desc: "複利滾存與節稅效益分析",       section: "投資與退休" },
    { href: "/tools/stock-calculator",         label: "股票損益試算",   desc: "現股、當沖與 ETF 手續費",     section: "投資與退休" },
    { href: "/tools/insurance-assessment",     label: "保險效益評估",   desc: "儲蓄險 IRR 與壽險需求",       section: "投資與退休" },
    { href: "/tools/credit-card-calculator",   label: "信用卡分期",     desc: "真實年利率 IRR 計算",          section: "投資與退休" },
    { href: "/tools/split-calculator",         label: "分帳計算",       desc: "聚餐旅遊 AA 制輕鬆搞定",      section: "生活工具" },
    { href: "/tools/percentage-calculator",    label: "百分比計算",     desc: "折扣、漲幅四種模式",           section: "生活工具" },
    { href: "/tools/profit-calculator",        label: "利潤試算",       desc: "成本、售價與毛利率",           section: "生活工具" },
];

const sections = [
    {
        id: "01",
        title: "薪資與稅務",
        desc: "計算實拿薪資、所得稅與加班費，確保您的勞動權益不打折。",
        icon: `<path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>`,
    },
    {
        id: "02",
        title: "居住與房產",
        desc: "評估房貸負擔、租金成本與居家能源消耗，找到適合的居住策略。",
        icon: `<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
    },
    {
        id: "03",
        title: "投資與退休",
        desc: "規劃 FIRE 退休目標，分析股票損益，讓錢替你工作。",
        icon: `<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
    },
    {
        id: "04",
        title: "生活工具",
        desc: "分帳、百分比與利潤計算，解決日常數字困擾。",
        icon: `<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18M9 21V9"/>`,
    },
];
---

<Layout title={title} description={description}>
    <main class="py-16 md:py-24">

        <!-- Hero -->
        <header class="mb-12 max-w-xl">
            <div class="flex items-center gap-2 mb-6">
                <span class="w-2 h-2 bg-azure rounded-full"></span>
                <span class="text-xs font-medium text-ink-400 tracking-widest uppercase">2026 最新費率</span>
            </div>
            <h1 class="text-4xl md:text-5xl font-normal text-ink-700 tracking-tight leading-tight mb-6">
                讓每一分錢<br>都算清楚
            </h1>
            <p class="text-base text-ink-400 leading-relaxed max-w-md mb-8">
                從薪資到退休，整合台灣最常用的財務計算工具。所有計算在本地執行，不需要帳號，完全免費。
            </p>

            <!-- 搜尋框 -->
            <div class="relative">
                <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-ink-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                </svg>
                <input id="tool-search" type="text" placeholder="搜尋工具…例如「薪資」「房貸」"
                    class="w-full pl-10 pr-4 py-3 bg-paper-200 border border-transparent rounded-xl text-sm text-ink-700
                           placeholder:text-ink-300 focus:outline-none focus:border-azure focus:bg-white focus:shadow-input transition-all duration-200" />
            </div>

            <!-- 搜尋結果 -->
            <div id="search-results" class="hidden mt-2 card-surface p-2 space-y-0.5 max-h-72 overflow-y-auto">
            </div>
        </header>

        <!-- Tool Grid -->
        <div id="tool-grid" class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-14">
            {sections.map((section) => {
                const tools = allTools.filter(t => t.section === section.title);
                return (
                    <section data-section={section.title}>
                        <div class="border-t border-paper-300 pt-5 mb-6">
                            <span class="text-[10px] font-medium text-ink-400 uppercase tracking-widest">Section {section.id}</span>
                            <div class="flex items-center gap-3 mt-3 mb-3">
                                <div class="w-8 h-8 rounded-lg bg-paper-200 flex items-center justify-center flex-shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ink-500" set:html={section.icon}></svg>
                                </div>
                                <h2 class="text-xl font-medium text-ink-700">{section.title}</h2>
                            </div>
                            <p class="text-sm text-ink-400 leading-relaxed">{section.desc}</p>
                        </div>
                        <ul class="space-y-2">
                            {tools.map((tool) => (
                                <li>
                                    <a href={tool.href}
                                       class="flex items-center justify-between py-3 px-4 bg-paper-200/40 rounded-xl hover:bg-paper-200 border border-transparent hover:border-paper-300 transition-all duration-150 group">
                                        <div class="flex items-center gap-3">
                                            <div class="flex flex-col">
                                                <div class="flex items-center gap-2">
                                                    <span class="text-sm font-medium text-ink-600 group-hover:text-ink-700 transition-colors">{tool.label}</span>
                                                    {tool.isNew && <span class="text-[10px] font-bold text-azure bg-azure-50 px-1.5 py-0.5 rounded-full border border-azure-200">NEW</span>}
                                                </div>
                                                <span class="text-xs text-ink-400 mt-0.5">{tool.desc}</span>
                                            </div>
                                        </div>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-300 group-hover:text-ink-500 group-hover:translate-x-0.5 transition-all flex-shrink-0 ml-3">
                                            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                                        </svg>
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </section>
                );
            })}
        </div>

        <!-- Trust Strip -->
        <div class="mt-20 pt-8 border-t border-paper-300 flex flex-wrap items-center gap-6">
            <div class="flex items-center gap-2 text-xs text-ink-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                本地計算，資料不上傳
            </div>
            <div class="flex items-center gap-2 text-xs text-ink-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                2026 最新法規費率
            </div>
            <div class="flex items-center gap-2 text-xs text-ink-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                免費，無需帳號
            </div>
        </div>
    </main>
</Layout>

<script>
// ── 搜尋功能 ────────────────────────────────────────────────────
const allTools = [
    { href: "/tools/salary-calculator",       label: "薪資實拿計算",   desc: "月薪扣除勞健保後實領多少",     tags: "薪資 月薪 勞保 健保" },
    { href: "/tools/income-tax-calculator",    label: "綜合所得稅試算", desc: "標準vs列舉扣除，最省稅方案",   tags: "所得稅 報稅 稅 扣除 股利" },
    { href: "/tools/insurance-calculator",     label: "勞健保計算",     desc: "費率級距與眷屬附保明細",       tags: "勞保 健保 保費 投保" },
    { href: "/tools/overtime-calculator",      label: "加班費試算",     desc: "平日、休息日、國定假日",       tags: "加班 加班費 休假 假日" },
    { href: "/tools/mortgage-calculator",      label: "房貸試算",       desc: "新青安、寬限期與提前還款",     tags: "房貸 買房 新青安 利率 貸款" },
    { href: "/tools/rent-cost-calculator",     label: "租金解析",       desc: "租屋押金與真實月支出",         tags: "租金 租屋 房租 押金" },
    { href: "/tools/electricity-calculator",   label: "電費試算",       desc: "台電累進費率自動計算",         tags: "電費 台電 電力 用電" },
    { href: "/tools/fire-calculator",          label: "FIRE 退休規劃",  desc: "複利效應與財務自由倒數",       tags: "退休 FIRE 財務自由 複利" },
    { href: "/tools/labor-pension-calculator", label: "勞退試算",       desc: "複利滾存與節稅效益分析",       tags: "勞退 勞工退休金 提撥 退休" },
    { href: "/tools/stock-calculator",         label: "股票損益試算",   desc: "現股、當沖與 ETF 手續費",     tags: "股票 ETF 手續費 損益 當沖" },
    { href: "/tools/split-calculator",         label: "分帳計算",       desc: "聚餐旅遊 AA 制輕鬆搞定",      tags: "分帳 AA 聚餐 旅遊" },
    { href: "/tools/percentage-calculator",    label: "百分比計算",     desc: "折扣、漲幅四種模式",           tags: "百分比 折扣 漲幅 計算" },
    { href: "/tools/credit-card-calculator",   label: "信用卡分期",     desc: "真實年利率 IRR 計算",          tags: "信用卡 分期 利率 IRR" },
];

const searchInput   = document.getElementById('tool-search');
const searchResults = document.getElementById('search-results');

searchInput?.addEventListener('input', (e) => {
    const q = e.target.value.trim();
    if (!q) {
        searchResults.classList.add('hidden');
        return;
    }

    const hits = allTools.filter(t =>
        t.label.includes(q) || t.desc.includes(q) || t.tags.includes(q)
    );

    if (!hits.length) {
        searchResults.innerHTML = `<p class="text-xs text-ink-400 px-3 py-2">找不到「${q}」的相關工具</p>`;
    } else {
        searchResults.innerHTML = hits.map(t => `
            <a href="${t.href}" class="flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-paper-200 transition-colors group">
                <div>
                    <p class="text-sm font-medium text-ink-700">${t.label}</p>
                    <p class="text-xs text-ink-400 mt-0.5">${t.desc}</p>
                </div>
                <svg class="text-ink-300 group-hover:text-ink-500 shrink-0" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
        `).join('');
    }
    searchResults.classList.remove('hidden');
});

// 點外部關閉搜尋結果
document.addEventListener('click', (e) => {
    if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.classList.add('hidden');
    }
});
</script>
