                           style={`animation-delay: ${toolIdx * 0.05}s`}>
                            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-brand-500 to-emerald-500 flex items-center justify-center flex-shrink-0 shadow-lg group-hover:shadow-xl transition-shadow duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={tool.icon}></svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <span class="text-sm font-medium text-ink-700 group-hover:text-brand transition-colors">{tool.label}</span>
                                <p class="text-xs text-ink-400 leading-relaxed mt-1">{tool.desc}</p>
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="text-base font-semibold text-ink-800 group-hover:text-brand-600 transition-colors">{tool.label}</span>
                                    {tool.isNew && <span class="badge-positive">NEW</span>}
