---
import Layout from '../layouts/Layout.astro';

const title = "TaiCalc 財務計算平台";
const description = "整合薪資、房貸與退休規劃的財務計算平台。2026 最新費率，所有計算在本地執行，安全隱私。";

const sections = [
    {
        id: "01",
        title: "薪資與權益",
        desc: "計算實拿薪資、勞健保費率與加班費，確保您的勞動權益不打折。",
        icon: `<path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>`,
        tools: [
            { href: "/tools/salary-calculator", label: "薪資實拿計算", desc: "月薪扣除勞健保後實領多少" },
            { href: "/tools/insurance-calculator", label: "勞健保計算", desc: "費率級距與眷屬附保明細" },
            { href: "/tools/overtime-calculator", label: "加班費試算", desc: "平日、休息日、國定假日" },
            { href: "/tools/delivery-income-calculator", label: "外送收入計算", desc: "跑單淨收入與油費成本" },
        ]
    },
    {
        id: "02",
        title: "居住與房產",
        desc: "評估房貸負擔、租金成本與居家能源消耗，找到適合的居住策略。",
        icon: `<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
        tools: [
            { href: "/tools/mortgage-calculator", label: "房貸試算", desc: "新青安、寬限期與提前還款" },
            { href: "/tools/rent-cost-calculator", label: "租金解析", desc: "租屋押金與真實月支出" },
            { href: "/tools/electricity-calculator", label: "電費試算", desc: "台電累進費率自動計算" },
            { href: "/tools/ac-installation-calculator", label: "冷氣評估", desc: "安裝費與回本年限試算" },
        ]
    },
    {
        id: "03",
        title: "投資與退休",
        desc: "規劃 FIRE 退休目標，分析股票損益，讓錢替你工作。",
        icon: `<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
        tools: [
            { href: "/tools/fire-calculator", label: "FIRE 退休規劃", desc: "複利效應與財務自由倒數" },
            { href: "/tools/stock-calculator", label: "股票損益試算", desc: "現股、當沖與 ETF 手續費" },
            { href: "/tools/insurance-assessment", label: "保險效益評估", desc: "儲蓄險 IRR 與壽險需求" },
            { href: "/tools/credit-card-calculator", label: "信用卡分期", desc: "真實年利率 IRR 計算" },
        ]
    },
    {
        id: "04",
        title: "生活工具",
        desc: "分帳、百分比計算與決策輔助工具，解決日常數字困擾。",
        icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
        tools: [
            { href: "/tools/split-calculator", label: "分帳計算", desc: "聚餐旅遊 AA 制輕鬆搞定" },
            { href: "/tools/percentage-calculator", label: "百分比計算", desc: "折扣、漲幅四種模式" },
            { href: "/tools/oracle", label: "易經決策", desc: "不確定性分析與決策輔助" },
            { href: "/lifeos", label: "LifeOS Audit", desc: "生活系統健康度評估" },
        ]
    },
];
---

<Layout title={title} description={description}>
    <main class="py-16 md:py-24">

        <!-- Hero -->
        <header class="mb-20 max-w-xl">
            <div class="flex items-center gap-2 mb-6">
                <span class="w-2 h-2 bg-azure rounded-full"></span>
                <span class="text-xs font-medium text-ink-400 tracking-widest uppercase">2026 最新費率</span>
            </div>
            <h1 class="text-4xl md:text-5xl font-normal text-ink-700 tracking-tight leading-tight mb-6">
                讓每一分錢<br>都算清楚
            </h1>
            <p class="text-base text-ink-400 leading-relaxed max-w-md">
                從薪資到退休，整合台灣最常用的財務計算工具。<br>
                所有計算在本地執行，不需要帳號，完全免費。
            </p>
        </header>

        <!-- Tool Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-14">
            {sections.map((section) => (
                <section>
                    <!-- Section header -->
                    <div class="border-t border-paper-300 pt-5 mb-6">
                        <div class="flex items-start justify-between mb-3">
                            <span class="text-[10px] font-medium text-ink-400 uppercase tracking-widest">Section {section.id}</span>
                        </div>
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-8 h-8 rounded-lg bg-paper-200 flex items-center justify-center flex-shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ink-500" set:html={section.icon}></svg>
                            </div>
                            <h2 class="text-xl font-medium text-ink-700">{section.title}</h2>
                        </div>
                        <p class="text-sm text-ink-400 leading-relaxed">{section.desc}</p>
                    </div>

                    <!-- Tool links -->
                    <ul class="space-y-2">
                        {section.tools.map((tool) => (
                            <li>
                                <a href={tool.href}
                                   class="flex items-center justify-between py-3 px-4 bg-paper-200/40 rounded-xl hover:bg-paper-200 hover:border-paper-300 border border-transparent transition-all duration-150 group">
                                    <div class="flex flex-col">
                                        <span class="text-sm font-medium text-ink-600 group-hover:text-ink-700 transition-colors">{tool.label}</span>
                                        <span class="text-xs text-ink-400 mt-0.5">{tool.desc}</span>
                                    </div>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-300 group-hover:text-ink-500 group-hover:translate-x-0.5 transition-all flex-shrink-0 ml-3">
                                        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                                    </svg>
                                </a>
                            </li>
                        ))}
                    </ul>
                </section>
            ))}
        </div>

        <!-- Bottom trust strip -->
        <div class="mt-20 pt-8 border-t border-paper-300 flex flex-wrap items-center gap-6">
            <div class="flex items-center gap-2 text-xs text-ink-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                本地計算，資料不上傳
            </div>
            <div class="flex items-center gap-2 text-xs text-ink-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                2026 最新法規費率
            </div>
            <div class="flex items-center gap-2 text-xs text-ink-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                免費，無需帳號
            </div>
        </div>
    </main>
</Layout>
